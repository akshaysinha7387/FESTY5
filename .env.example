# =============================================
# Copy this to .env and fill in the values
# =============================================

# --- LOCAL DEV (SQLite) ---
# DATABASE_URL="file:./dev.db"

# --- PRODUCTION (Railway PostgreSQL) ---
# Get this from Railway: your project → PostgreSQL service → Variables → DATABASE_URL
DATABASE_URL="postgresql://user:password@hostname.railway.internal:5432/railway"

# Generate a strong random string: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-secret"

# Your Railway public domain (set after first deploy)
NEXTAUTH_URL="https://your-app.up.railway.app"
