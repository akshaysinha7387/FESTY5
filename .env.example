# =============================================
# Copy this to .env and fill in the values
# =============================================

# --- LOCAL DEV (SQLite) ---
# DATABASE_URL="file:./dev.db"
# DIRECT_URL="file:./dev.db"

# --- PRODUCTION (Neon PostgreSQL) ---
# Get these from https://neon.tech → your project → Connection Details
# Select "Prisma" as the framework to get the correct format
DATABASE_URL="postgres://user:password@ep-xxx.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgres://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# Generate a strong random string: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-secret"

# Your Vercel deployment URL (update after first deploy)
NEXTAUTH_URL="https://your-app.vercel.app"
