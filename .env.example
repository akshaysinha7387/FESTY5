# Copy this to .env and fill in the values

# For local dev: file:./dev.db
# For Railway: paste the Railway SQLite path or switch to Turso/PostgreSQL
DATABASE_URL="file:./dev.db"

# Generate a strong random string (e.g. openssl rand -base64 32)
NEXTAUTH_SECRET="replace-with-a-strong-secret"

# Your deployment URL (e.g. https://festy5.up.railway.app)
NEXTAUTH_URL="http://localhost:3000"
