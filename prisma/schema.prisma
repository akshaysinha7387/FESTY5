// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon requires directUrl for migrations
  directUrl = env("DIRECT_URL")
}

enum Role {
  FestHead
  EventHead
  SponsorshipLead
}

enum EventStatus {
  Planning
  Active
  Completed
}

enum SponsorStage {
  Lead
  Contacted
  InDiscussion
  Negotiation
  ClosedWon
  ClosedLost
}

enum DeliverableStatus {
  Pending
  InProgress
  Completed
}

model User {
  id        String @id @default(cuid())
  name      String
  email     String @unique
  password  String
  role      Role

  // Relations
  headOfEvents         Event[]        @relation("EventHead")
  ownedSponsors        Sponsor[]      @relation("SponsorOwner")
  weeklyUpdates        WeeklyUpdate[]
  assignedDeliverables Deliverable[]  @relation("DeliverableAssignee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Fest {
  id                       String   @id @default(cuid())
  fest_name                String
  prep_start_date          DateTime
  fest_start_date          DateTime
  fest_end_date            DateTime
  total_sponsorship_target Float

  // Relations
  events Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id                 String      @id @default(cuid())
  fest_id            String
  event_name         String
  event_head_id      String
  sponsorship_target Float
  status             EventStatus @default(Planning)

  // Relations
  fest         Fest          @relation(fields: [fest_id], references: [id], onDelete: Cascade)
  eventHead    User          @relation("EventHead", fields: [event_head_id], references: [id])
  sponsors     Sponsor[]
  deliverables Deliverable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sponsor {
  id                     String       @id @default(cuid())
  sponsor_name           String
  linked_event_id        String
  owner_id               String
  expected_amount        Float
  probability_percentage Float        @default(50)
  stage                  SponsorStage @default(Lead)
  last_updated_at        DateTime     @default(now())
  notes                  String       @default("")

  // Relations
  linkedEvent   Event          @relation(fields: [linked_event_id], references: [id], onDelete: Cascade)
  owner         User           @relation("SponsorOwner", fields: [owner_id], references: [id])
  weeklyUpdates WeeklyUpdate[]
  deliverables  Deliverable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WeeklyUpdate {
  id                 String   @id @default(cuid())
  sponsor_id         String
  updated_by_user_id String
  update_summary     String
  blockers           String   @default("")
  next_steps         String   @default("")
  created_at         DateTime @default(now())

  // Relations
  sponsor   Sponsor @relation(fields: [sponsor_id], references: [id], onDelete: Cascade)
  updatedBy User    @relation(fields: [updated_by_user_id], references: [id])
}

model Deliverable {
  id                  String            @id @default(cuid())
  sponsor_id          String?
  event_id            String
  title               String
  description         String            @default("")
  assigned_to_user_id String
  due_date            DateTime
  status              DeliverableStatus @default(Pending)

  // Relations
  sponsor    Sponsor? @relation(fields: [sponsor_id], references: [id], onDelete: SetNull)
  event      Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  assignedTo User     @relation("DeliverableAssignee", fields: [assigned_to_user_id], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
